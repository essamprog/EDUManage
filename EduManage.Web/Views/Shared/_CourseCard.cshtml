@model CourseDto

<div class="card h-100 border-0 shadow-sm hover-shadow">
    <a asp-controller="Courses" asp-action="Details" asp-route-id="@Model.Id"
           class="text-decoration-none">
        <img src="@(Model.ThumbnailUrl ?? "/images/course-default.jpg")"
             class="card-img-top" alt="@Model.Title"
             style="height:160px;object-fit:cover" />
    </a>
    <div class="card-body d-flex flex-column">

        @if (Model.IsBestseller)
        {
            <span class="badge bg-warning text-dark mb-2" style="width:fit-content">
                <i class="bi bi-star-fill me-1"></i>Bestseller
            </span>
        }

        <h6 class="card-title fw-bold mb-1">
            <a asp-controller="Courses" asp-action="Details" asp-route-id="@Model.Id"
                   class="text-dark text-decoration-none stretched-link">
                @Model.Title
            </a>
        </h6>
        <p class="text-muted small mb-2">@Model.InstructorName</p>

        <div class="d-flex align-items-center gap-1 mb-2">
            <span class="fw-bold text-warning small">@Model.AverageRating.ToString("F1")</span>
            @for (int i = 1; i <= 5; i++)
            {
                <i class="bi bi-star@(i <= (int)Model.AverageRating ? "-fill" : i - 0.5m <= Model.AverageRating ? "-half" : "") text-warning"
                   style="font-size:11px"></i>
            }
            <span class="text-muted" style="font-size:11px">(@Model.TotalStudents)</span>
        </div>

        <div class="d-flex align-items-center gap-2 small text-muted mb-3">
            <span><i class="bi bi-play-circle me-1"></i>@Model.TotalLessons Lessons</span>
            <span><i class="bi bi-bar-chart me-1"></i>@Model.Level</span>
        </div>

        <div class="mt-auto">
            <span class="fw-bold text-primary fs-5">EGP @Model.Price.ToString("N0")</span>
        </div>

    </div>
</div>