@model IEnumerable<EduManage.Application.DTOs.Courses.CourseDto>

<section class="hero-section bg-dark text-white pt-5 pb-5 mb-5 shadow" style="border-radius: 0 0 40px 40px;">
    <div class="container py-5">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <span class="badge bg-primary bg-opacity-25 text-primary mb-3 px-3 py-2 rounded-pill fs-6">
                    Welcome to EduManage
                </span>
                <h1 class="display-4 fw-bolder lh-sm mb-4">
                    Unlock Your Potential with Top-Tier Courses
                </h1>
                <p class="lead text-secondary mb-5">
                    Build your future with world-class instructors. Explore a wide variety of topics, master new skills, and advance your career today.
                </p>
                <div class="d-flex gap-3">
                    <a href="#courses-grid" class="btn btn-primary btn-lg px-4 rounded-pill fw-bold shadow-sm">
                        Start Learning
                    </a>
                    <a href="/Courses/Create" class="btn btn-outline-light btn-lg px-4 rounded-pill fw-bold">
                        Add New Course
                    </a>
                </div>
            </div>
            
            <div class="col-lg-6 text-center">
                <img src="https://cdni.iconscout.com/illustration/premium/thumb/online-learning-4488770-3759902.png" 
                     alt="E-Learning 3D Illustration" 
                     class="img-fluid floating-img" 
                     style="max-height: 450px; filter: drop-shadow(0 20px 30px rgba(0,0,0,0.3));">
            </div>
        </div>
    </div>
</section>

<section id="courses-grid" class="container mb-5 pb-5">
    
    <div class="d-flex justify-content-between align-items-center mb-5">
        <h2 class="fw-bold text-dark">Trending Courses 🔥</h2>
        <a href="/Courses" class="text-decoration-none fw-bold">View All &rarr;</a>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var course in Model)
            {
                <div class="col-md-4 col-sm-6">
                    <div class="card h-100 border-0 shadow-sm course-card" style="border-radius: 16px; overflow: hidden;">
                        
                        <div class="position-relative">
                            <img src="@course.ThumbnailUrl" class="card-img-top" alt="@course.Title" style="height: 220px; object-fit: cover;">
                            <span class="position-absolute top-0 end-0 m-3 badge bg-dark bg-opacity-75 rounded-pill px-3 py-2">
                                @(course.Level.ToString() ?? "All Levels")
                            </span>
                        </div>
                        
                        <div class="card-body d-flex flex-column p-4">
                            <h5 class="card-title fw-bold text-dark mb-3">@course.Title</h5>
                            <p class="card-text text-muted small mb-4 flex-grow-1">
                                @(course.Description ?? "No description available for this course yet.")
                            </p>
                            
                            <div class="mt-auto d-flex justify-content-between align-items-center border-top pt-3">
                                <span class="fw-bolder fs-5 text-dark">
                                    @(course.Price > 0 ? $"${course.Price}" : "Free")
                                </span>
                                <a href="#" class="btn btn-primary btn-sm rounded-pill px-4 fw-bold">Enroll Now</a>
                            </div>
                        </div>

                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5 mt-4 bg-light rounded-4">
                <img src="https://cdn-icons-png.flaticon.com/512/7486/7486831.png" alt="No Courses" width="100" class="mb-3 opacity-50">
                <h4 class="text-muted fw-bold">No courses available</h4>
                <p class="text-muted">The platform is currently empty. Start by adding a new course.</p>
            </div>
        }
    </div>
</section>

<style>
    /* Floating animation for the 3D Hero image */
    .floating-img {
        animation: float 6s ease-in-out infinite;
    }

    @@keyframes float {
        0% { transform: translateY(0px); }
        50% { transform: translateY(-20px); }
        100% { transform: translateY(0px); }
    }

    /* Smooth hover effect for course cards */
    .course-card {
        transition: all 0.3s ease;
    }
    
    .course-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
    }
</style>