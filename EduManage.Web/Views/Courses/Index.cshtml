@using EduManage.Application.DTOs.Common
@using EduManage.Core.Entities
@using EduManage.Web.Models
@model PagedResult<CourseDto>
@{
    ViewData["Title"] = "Courses";
}

<div class="container py-4">
    <div class="row g-4">

        {{!-- Sidebar Filters --}}
        <div class="col-lg-3">
            <div class="card border-0 shadow-sm p-3">
                <h6 class="fw-bold mb-3"><i class="bi bi-funnel me-1"></i>Filter Results</h6>

                <form asp-action="Index" method="get" id="filterForm">
                    <input type="hidden" name="search" value="@ViewData["Search"]" />

                    <div class="mb-3">
                        <label class="form-label small fw-bold">Category</label>
                        <select name="categoryId" class="form-select form-select-sm"
                                onchange="document.getElementById('filterForm').submit()">
                            <option value="">All</option>
                            @foreach (var cat in ViewData["Categories"] as IEnumerable<Category> ?? [])
                            {
                                <option value="@cat.Id"
                                        selected="@(ViewData["CategoryId"]?.ToString() == cat.Id.ToString())">
                                    @cat.Name
                                </option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold">Level</label>
                        @foreach (var level in new[] { "Beginner", "Intermediate", "Advanced" })
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="level"
                                       value="@level" id="level_@level"
                                       onchange="document.getElementById('filterForm').submit()"
                                       checked="@(ViewData["Level"]?.ToString() == level)" />
                                <label class="form-check-label small" for="level_@level">
                                    @level
                                </label>
                            </div>
                        }
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold">Sort By</label>
                        <select name="sortBy" class="form-select form-select-sm"
                                onchange="document.getElementById('filterForm').submit()">
                            <option value="newest">Newest</option>
                            <option value="popular">Most Popular</option>
                            <option value="rating">Highest Rated</option>
                            <option value="price-asc">Price: Low to High</option>
                            <option value="price-desc">Price: High to Low</option>
                        </select>
                    </div>

                    <button type="button" class="btn btn-outline-secondary btn-sm w-100"
                            onclick="window.location='@Url.Action("Index")'">
                        <i class="bi bi-x-circle me-1"></i>Clear Filters
                    </button>
                </form>
            </div>
        </div>

        {{!-- Results --}}
        <div class="col-lg-9">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0 fw-bold">
                    @Model.Total Courses
                    @if (!string.IsNullOrEmpty(ViewData["Search"] as string))
                    {
                        <span class="text-muted fw-normal fs-6">
                            for "@ViewData["Search"]"
                        </span>
                    }
                </h5>
            </div>

            @if (!Model.Items.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-search display-1 text-muted"></i>
                    <h5 class="mt-3 text-muted">No results found</h5>
                    <p class="text-muted">Try different search terms or clear filters</p>
                </div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var course in Model.Items)
                    {
                        <div class="col-sm-6 col-xl-4">
                            <partial name="_CourseCard" model="course" />
                        </div>
                    }
                </div>

                @* Pagination *@
                @if (Model.TotalPages > 1)
                {
                    <nav class="mt-4">
                        <ul class="pagination justify-content-center">
                            <li class="page-item @(!Model.HasPrev ? "disabled" : "")">
                                <a class="page-link"
                                       asp-action="Index"
                                       asp-route-page="@(Model.Page - 1)"
                                       asp-route-search="@ViewData["Search"]">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>
                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.Page ? "active" : "")">
                                    <a class="page-link"
                                       asp-action="Index"
                                       asp-route-page="@i"
                                       asp-route-search="@ViewData["Search"]">@i</a>
                                </li>
                            }
                            <li class="page-item @(!Model.HasNext ? "disabled" : "")">
                                <a class="page-link"
                                       asp-action="Index"
                                       asp-route-page="@(Model.Page + 1)"
                                       asp-route-search="@ViewData["Search"]">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                }
            }
        </div>

    </div>
</div>