@using EduManage.Application.DTOs.Courses
@{
    ViewData["Title"] = "Instructor Dashboard"; Layout = "_Layout";
}

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0">
            <i class="bi bi-easel me-2 text-primary"></i>Instructor Dashboard
        </h4>
        <a asp-controller="Instructor" asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>New Course
        </a>
    </div>

    @if (TempData["Success"] is string success)
    {
        <div class="alert alert-success alert-dismissible">
            <i class="bi bi-check-circle me-1"></i>@success
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Stats -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <div class="fs-2 fw-bold text-primary">@ViewData["TotalCourses"]</div>
                <div class="text-muted small"><i class="bi bi-grid me-1"></i>My Courses</div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <div class="fs-2 fw-bold text-success">@ViewData["TotalStudents"]</div>
                <div class="text-muted small"><i class="bi bi-people me-1"></i>Total Students</div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <div class="fs-2 fw-bold text-warning">
                    @((ViewData["AvailableBalance"] as decimal?)?.ToString("N0")) EGP
                </div>
                <div class="text-muted small"><i class="bi bi-wallet2 me-1"></i>Available Balance</div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <div class="fs-2 fw-bold text-info">
                    @((ViewData["LifetimeEarnings"] as decimal?)?.ToString("N0")) EGP
                </div>
                <div class="text-muted small"><i class="bi bi-cash me-1"></i>Lifetime Earnings</div>
            </div>
        </div>
    </div>

    <!-- Quick Links -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <a asp-controller="Instructor" asp-action="Courses"
                   class="card border-0 shadow-sm p-3 text-decoration-none text-dark
                d-flex flex-row align-items-center gap-3">
                <div class="bg-primary bg-opacity-10 rounded p-2">
                    <i class="bi bi-grid fs-4 text-primary"></i>
                </div>
                <div>
                    <div class="fw-bold">Manage Courses</div>
                    <div class="text-muted small">Edit, publish, delete</div>
                </div>
                <i class="bi bi-chevron-left ms-auto text-muted"></i>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-controller="Instructor" asp-action="Create"
                   class="card border-0 shadow-sm p-3 text-decoration-none text-dark
                d-flex flex-row align-items-center gap-3">
                <div class="bg-success bg-opacity-10 rounded p-2">
                    <i class="bi bi-plus-circle fs-4 text-success"></i>
                </div>
                <div>
                    <div class="fw-bold">Create Course</div>
                    <div class="text-muted small">Add a new course</div>
                </div>
                <i class="bi bi-chevron-left ms-auto text-muted"></i>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-controller="Instructor" asp-action="Financials"
                   class="card border-0 shadow-sm p-3 text-decoration-none text-dark
                d-flex flex-row align-items-center gap-3">
                <div class="bg-warning bg-opacity-10 rounded p-2">
                    <i class="bi bi-wallet2 fs-4 text-warning"></i>
                </div>
                <div>
                    <div class="fw-bold">My Earnings</div>
                    <div class="text-muted small">Wallet & withdrawals</div>
                </div>
                <i class="bi bi-chevron-left ms-auto text-muted"></i>
            </a>
        </div>
    </div>

    <!-- Courses Table -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 py-3 d-flex justify-content-between">
            <h6 class="fw-bold mb-0">My Courses</h6>
            <a asp-controller="Instructor" asp-action="Courses"
               class="btn btn-outline-primary btn-sm">View All</a>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Course</th>
                            <th class="text-center">Students</th>
                            <th class="text-center">Rating</th>
                            <th class="text-center">Price</th>
                            <th class="text-center">Status</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var course in ViewData["Courses"] as IEnumerable<CourseDto> ?? [])
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <img src="@(course.ThumbnailUrl ?? "/images/course-default.jpg")"
                                             style="width:48px;height:36px;object-fit:cover;border-radius:6px"
                                             alt="@course.Title" />
                                        <div>
                                            <div class="fw-bold small">@course.Title</div>
                                            <div class="text-muted" style="font-size:11px">@course.CategoryName</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-center small">@course.TotalStudents</td>
                                <td class="text-center small">
                                    <i class="bi bi-star-fill text-warning"></i>
                                    @course.AverageRating.ToString("F1")
                                </td>
                                <td class="text-center small fw-bold">@course.Price.ToString("N0") EGP</td>
                                <td class="text-center">
                                    <span class="badge @(course.Status == "Published" ? "bg-success" :
                                                                                                       course.Status == "Draft" ? "bg-secondary" :
                                                                                                       "bg-warning text-dark")">
                                        @course.Status
                                    </span>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm">
                                        <a asp-controller="Instructor" asp-action="Edit"
                                               asp-route-id="@course.Id"
                                               class="btn btn-outline-primary" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        @if (course.Status != "Published")
                                        {
                                            <form asp-controller="Instructor" asp-action="Publish"
                                                  method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@course.Id" />
                                                <button class="btn btn-outline-success btn-sm" type="submit"
                                                        title="Publish">
                                                    <i class="bi bi-send"></i>
                                                </button>
                                            </form>
                                        }
                                        <form asp-controller="Instructor" asp-action="Delete"
                                              method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@course.Id" />
                                            <button class="btn btn-outline-danger btn-sm" type="submit"
                                                    onclick="return confirm('Delete this course?')"
                                                    title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>