@using EduManage.Application.DTOs.Courses
@model IEnumerable<CourseDto>
@{
    ViewData["Title"] = "My Courses"; Layout = "_Layout";
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0">
            <i class="bi bi-grid me-2 text-primary"></i>My Courses
        </h4>
        <a asp-controller="Instructor" asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>New Course
        </a>
    </div>

    @if (TempData["Success"] is string success)
    {
        <div class="alert alert-success alert-dismissible">
            <i class="bi bi-check-circle me-1"></i>@success
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] is string error)
    {
        <div class="alert alert-danger alert-dismissible">
            <i class="bi bi-exclamation-triangle me-1"></i>@error
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-grid display-1 text-muted"></i>
            <h5 class="mt-3 text-muted">No courses yet</h5>
            <p class="text-muted">Create your first course and start teaching</p>
            <a asp-controller="Instructor" asp-action="Create" class="btn btn-primary mt-2">
                <i class="bi bi-plus-circle me-1"></i>Create Course
            </a>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Course</th>
                                <th class="text-center">Students</th>
                                <th class="text-center">Rating</th>
                                <th class="text-center">Price</th>
                                <th class="text-center">Status</th>
                                <th class="text-center">Created</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var course in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            <img src="@(course.ThumbnailUrl ?? "/images/course-default.jpg")"
                                                 style="width:56px;height:42px;object-fit:cover;border-radius:6px"
                                                 alt="@course.Title" />
                                            <div>
                                                <div class="fw-bold small">@course.Title</div>
                                                @if (!string.IsNullOrEmpty(course.Subtitle))
                                                {
                                                    <div class="text-muted" style="font-size:11px">@course.Subtitle</div>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center small">
                                        <i class="bi bi-people me-1 text-muted"></i>@course.TotalStudents
                                    </td>
                                    <td class="text-center small">
                                        <i class="bi bi-star-fill text-warning"></i>
                                        @course.AverageRating.ToString("F1")
                                    </td>
                                    <td class="text-center fw-bold small">@course.Price.ToString("N0") EGP</td>
                                    <td class="text-center">
                                        <span class="badge @(course.Status == "Published" ? "bg-success"  :
                                                                                                               course.Status == "Draft" ? "bg-secondary" :
                                                                                                               course.Status == "Archived" ? "bg-dark" :
                                                                                                               "bg-warning text-dark")">
                                            @course.Status
                                        </span>
                                    </td>
                                    <td class="text-center small text-muted">
                                        @course.CreatedAt.ToString("MMM dd, yyyy")
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm">
                                            <a asp-controller="Courses" asp-action="Details"
                                                   asp-route-id="@course.Id"
                                                   class="btn btn-outline-secondary" title="Preview">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-controller="Instructor" asp-action="Edit"
                                                   asp-route-id="@course.Id"
                                                   class="btn btn-outline-primary" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            @if (course.Status != "Published")
                                            {
                                                <form asp-controller="Instructor" asp-action="Publish"
                                                      method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@course.Id" />
                                                    <button class="btn btn-outline-success" type="submit"
                                                            title="Publish"
                                                            onclick="return confirm('Publish this course?')">
                                                        <i class="bi bi-send"></i>
                                                    </button>
                                                </form>
                                            }
                                            <form asp-controller="Instructor" asp-action="Delete"
                                                  method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@course.Id" />
                                                <button class="btn btn-outline-danger" type="submit"
                                                        title="Delete"
                                                        onclick="return confirm('Delete this course permanently?')">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

</div>