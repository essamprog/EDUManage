@model CartDto
@{
    ViewData["Title"] = "Checkout";
}

<div class="container py-4">
    <h4 class="fw-bold mb-4">
        <i class="bi bi-credit-card me-2"></i>Checkout
    </h4>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-4">Payment Details</h6>

                    <form asp-action="Checkout" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label">Payment Method</label>
                            <select name="PaymentMethod" class="form-select">
                                <option value="paymob">Paymob</option>
                                <option value="vodafone_cash">Vodafone Cash</option>
                                <option value="fawry">Fawry</option>
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Transaction ID</label>
                            <input type="text" name="TransactionId" class="form-control"
                                   placeholder="Enter the transaction ID after payment" />
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-success btn-lg">
                                <i class="bi bi-check-circle me-1"></i>Confirm Order
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="fw-bold mb-3">Order Summary</h6>
                    @foreach (var item in Model.Items)
                    {
                        <div class="d-flex justify-content-between mb-2 small">
                            <span class="text-muted">@item.Title</span>
                            <span>EGP @item.Price.ToString("N0")</span>
                        </div>
                    }
                    <hr />
                    <div class="d-flex justify-content-between fw-bold">
                        <span>Total</span>
                        <span class="text-primary">EGP @Model.TotalPrice.ToString("N0")</span>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>