@using EduManage.Core.Entities
@using EduManage.Core.Enums
@model IEnumerable<Course>
@{
    ViewData["Title"] = "All Courses"; Layout = "_Layout";
}

<div class="container-fluid py-4">

    <h4 class="fw-bold mb-4">
        <i class="bi bi-grid me-2 text-primary"></i>All Courses
    </h4>

    @if (TempData["Success"] is string success)
    {
        <div class="alert alert-success alert-dismissible">
            <i class="bi bi-check-circle me-1"></i>@success
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Search -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body py-2">
            <form asp-controller="Admin" asp-action="Courses" method="get"
                  class="d-flex gap-2">
                <input type="text" name="search" class="form-control"
                       placeholder="Search by title..."
                       value="@ViewData["Search"]" />
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-search"></i>
                </button>
                @if (!string.IsNullOrEmpty(ViewData["Search"] as string))
                {
                    <a asp-controller="Admin" asp-action="Courses"
                       class="btn btn-outline-secondary">Clear</a>
                }
            </form>
        </div>
    </div>

    <!-- Table -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 py-3 d-flex justify-content-between">
            <h6 class="fw-bold mb-0">@Model.Count() courses found</h6>
            <a asp-controller="Admin" asp-action="Pending"
                   class="btn btn-warning btn-sm">
                <i class="bi bi-hourglass-split me-1"></i>Pending Review
            </a>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Course</th>
                            <th class="text-center">Instructor</th>
                            <th class="text-center">Students</th>
                            <th class="text-center">Price</th>
                            <th class="text-center">Status</th>
                            <th class="text-center">Created</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var course in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <img src="@(course.ThumbnailUrl ?? "/images/course-default.jpg")"
                                             style="width:56px;height:42px;object-fit:cover;border-radius:6px"
                                             alt="@course.Title" />
                                        <div>
                                            <div class="fw-bold small">@course.Title</div>
                                            <span class="badge bg-light text-dark border"
                                                  style="font-size:10px">@course.Level</span>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-center small text-muted">
                                    ID: @course.InstructorId
                                </td>
                                <td class="text-center small">@course.TotalStudents</td>
                                <td class="text-center fw-bold small">
                                    @course.Price.ToString("N0") EGP
                                </td>
                                <td class="text-center">
                                    <span class="badge @(course.Status == CourseStatus.Published ? "bg-success"  :
                                                                                                       course.Status == CourseStatus.Draft ? "bg-secondary" :
                                                                                                       course.Status == CourseStatus.Pending ? "bg-warning text-dark" :
                                                                                                       course.Status == CourseStatus.Archived ? "bg-dark" :
                                                                                                       "bg-info")">
                                        @course.Status
                                    </span>
                                </td>
                                <td class="text-center small text-muted">
                                    @course.CreatedAt.ToString("MMM dd, yyyy")
                                </td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm">
                                        <a asp-controller="Courses" asp-action="Details"
                                               asp-route-id="@course.Id"
                                               class="btn btn-outline-secondary" title="Preview">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (course.Status == CourseStatus.Pending)
                                        {
                                            <form asp-controller="Admin" asp-action="Approve"
                                                  method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@course.Id" />
                                                <button class="btn btn-outline-success" type="submit"
                                                        title="Approve">
                                                    <i class="bi bi-check-lg"></i>
                                                </button>
                                            </form>
                                            <form asp-controller="Admin" asp-action="Reject"
                                                  method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@course.Id" />
                                                <button class="btn btn-outline-danger" type="submit"
                                                        title="Reject">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            </form>
                                        }
                                        @if (course.Status == CourseStatus.Published)
                                        {
                                            <form asp-controller="Admin" asp-action="Archive"
                                                  method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@course.Id" />
                                                <button class="btn btn-outline-dark" type="submit"
                                                        title="Archive"
                                                        onclick="return confirm('Archive this course?')">
                                                    <i class="bi bi-archive"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>