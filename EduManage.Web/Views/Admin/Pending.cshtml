@using EduManage.Core.Entities
@model IEnumerable<Course>
@{
    ViewData["Title"] = "Pending Courses"; Layout = "_Layout";
}

<div class="container-fluid py-4">

    <h4 class="fw-bold mb-4">
        <i class="bi bi-hourglass-split me-2 text-warning"></i>Courses Pending Review
    </h4>

    @if (TempData["Success"] is string s)
    {
        <div class="alert alert-success alert-dismissible">
            <i class="bi bi-check-circle me-1"></i>@s
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] is string e)
    {
        <div class="alert alert-danger alert-dismissible">
            <i class="bi bi-exclamation-triangle me-1"></i>@e
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-check-circle display-1 text-success"></i>
            <h5 class="mt-3 text-muted">No courses pending review</h5>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var course in Model)
            {
                <div class="col-lg-6">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">

                            <div class="d-flex gap-3">
                                <img src="@(course.ThumbnailUrl ?? "/images/course-default.jpg")"
                                     style="width:80px;height:60px;object-fit:cover;border-radius:8px"
                                     alt="@course.Title" />
                                <div class="flex-grow-1">
                                    <h6 class="fw-bold mb-1">@course.Title</h6>
                                    <div class="d-flex gap-2 flex-wrap">
                                        <span class="badge bg-light text-dark border">@course.Level</span>
                                        <span class="badge bg-light text-dark border">@course.Language</span>
                                        <span class="fw-bold text-primary small">@course.Price.ToString("N0") EGP</span>
                                    </div>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(course.Description))
                            {
                                <p class="text-muted small mt-3 mb-3">
                                    @(course.Description.Length > 150
                                      ? course.Description[..150] + "..."
                                      : course.Description)
                                </p>
                            }

                            <div class="d-flex gap-2 mt-3">
                                <form asp-action="Approve" method="post" class="flex-grow-1">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@course.Id" />
                                    <div class="d-grid">
                                        <button type="submit" class="btn btn-success btn-sm">
                                            <i class="bi bi-check-lg me-1"></i>Approve & Publish
                                        </button>
                                    </div>
                                </form>
                                <form asp-action="Reject" method="post" class="flex-grow-1">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@course.Id" />
                                    <div class="d-grid">
                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                            <i class="bi bi-x-lg me-1"></i>Reject
                                        </button>
                                    </div>
                                </form>
                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>
    }

</div>