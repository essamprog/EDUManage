@using EduManage.Core.Entities
@using EduManage.Core.Enums
@{
    ViewData["Title"] = "Finance Overview"; Layout = "_Layout";
}

<div class="container-fluid py-4">

    <h4 class="fw-bold mb-4">
        <i class="bi bi-wallet2 me-2 text-success"></i>Finance Overview
    </h4>

    @if (TempData["Success"] is string s)
    {
        <div class="alert alert-success alert-dismissible">
            <i class="bi bi-check-circle me-1"></i>@s
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] is string e)
    {
        <div class="alert alert-danger alert-dismissible">
            @e
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Stats -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center p-3">
                <div class="fs-3 fw-bold text-success mb-1">
                    @((ViewData["TotalRevenue"] as decimal?)?.ToString("N0")) EGP
                </div>
                <div class="text-muted small">Total Revenue</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center p-3">
                <div class="fs-3 fw-bold text-primary mb-1">
                    @((ViewData["PlatformEarnings"] as decimal?)?.ToString("N0")) EGP
                </div>
                <div class="text-muted small">Platform Earnings (20%)</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center p-3">
                <div class="fs-3 fw-bold text-warning mb-1">
                    @((ViewData["PendingWithdrawals"] as decimal?)?.ToString("N0")) EGP
                </div>
                <div class="text-muted small">Pending Withdrawals</div>
            </div>
        </div>
    </div>

    <!-- Withdrawal Requests -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 pt-3">
            <h6 class="fw-bold mb-0">Withdrawal Requests</h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Instructor ID</th>
                            <th>Amount</th>
                            <th>Method</th>
                            <th>Account</th>
                            <th>Requested</th>
                            <th class="text-center">Status</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var w in ViewData["Withdrawals"] as IEnumerable<Withdrawal> ?? [])
                        {
                            <tr>
                                <td class="small text-muted">#@w.Id</td>
                                <td class="small">@w.InstructorId</td>
                                <td class="fw-bold small">@w.Amount.ToString("N0") EGP</td>
                                <td class="small">@w.Method</td>
                                <td class="small text-muted">@w.AccountDetail</td>
                                <td class="small text-muted">@w.RequestedAt.ToString("MMM dd, yyyy")</td>
                                <td class="text-center">
                                    <span class="badge @(w.Status == WithdrawalStatus.Paid     ? "bg-success"  :
                                                                                                                                                                                         w.Status == WithdrawalStatus.Pending ? "bg-warning text-dark" :
                                                                                                                                                                                         w.Status == WithdrawalStatus.Approved ? "bg-info" :
                                                                                                                                                                                         "bg-danger")">
                                        @w.Status
                                    </span>
                                </td>
                                <td class="text-center">
                                    @if (w.Status == WithdrawalStatus.Pending)
                                    {
                                        <div class="btn-group btn-group-sm">
                                            <form asp-action="ApproveWithdrawal" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@w.Id" />
                                                <button class="btn btn-success btn-sm" type="submit"
                                                        onclick="return confirm('Mark as paid?')">
                                                    <i class="bi bi-check-lg"></i>
                                                </button>
                                            </form>
                                            <form asp-action="RejectWithdrawal" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@w.Id" />
                                                <button class="btn btn-outline-danger btn-sm" type="submit"
                                                        onclick="return confirm('Reject this withdrawal?')">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            </form>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>