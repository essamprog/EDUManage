@{
    ViewData["Title"] = "Password Recovery";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">

                    <h5 class="fw-bold mb-1">
                        <i class="bi bi-key text-primary me-1"></i>Password Recovery
                    </h5>
                    <p class="text-muted small mb-4">We will send a reset link to your email</p>

                    @if (ViewData["Success"] is true)
                    {
                        <div class="alert alert-success">
                            <i class="bi bi-check-circle me-1"></i>
                            The reset link has been sent to your email
                        </div>
                    }
                    else
                    {
                        <form asp-action="ForgotPassword" method="post">
                            @Html.AntiForgeryToken()
                            <div class="mb-3">
                                <label class="form-label">Email Address</label>
                                <input type="email" name="email" class="form-control"
                                       placeholder="example@email.com" required />
                            </div>
                            <div class="d-grid">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-send me-1"></i>Send Reset Link
                                </button>
                            </div>
                        </form>
                    }

                    <div class="text-center mt-3">
                        <a asp-action="Login" class="small text-decoration-none">
                            <i class="bi bi-arrow-left me-1"></i>Back to Login
                        </a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>